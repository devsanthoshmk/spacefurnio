meta {
  name: Add to Wishlist
  type: http
  seq: 4
}

post {
  url: https://ep-ancient-frog-aimehta7.apirest.c-4.us-east-1.aws.neon.tech/neondb/rest/v1/wishlist_items
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Prefer: return=representation, resolution=merge-duplicates
}

body:json {
  {
    "wishlist_id": "55555555-5555-5555-5555-555555555555",
    "product_id": "22222222-2222-2222-2222-222222222222"
  }
}

tests {
  test("status is 201 or 409", function() {
    expect([201, 409]).to.include(res.getStatus());
  });
}
